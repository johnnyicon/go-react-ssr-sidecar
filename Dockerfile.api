# Stage 1: Build the Go API binary
FROM golang:1.23-alpine AS go-builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -buildvcs=false -o app-api ./cmd/api

# Stage 2: Minimal runtime image
FROM alpine:3.21
WORKDIR /app
RUN apk add --no-cache ca-certificates tzdata
COPY --from=go-builder /app/app-api .
EXPOSE 8080
CMD ["./app-api"]
